# AccessAI Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Vertex AI Configuration (RECOMMENDED - uses GCP quotas, not API key quota)
# =============================================================================
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=cloud-location
GOOGLE_GENAI_USE_VERTEXAI=true

# Note: You need to authenticate with Google Cloud for Vertex AI:
#   1. Install gcloud: https://cloud.google.com/sdk/docs/install
#   2. Run: gcloud auth application-default login
#   3. Enable Vertex AI API: https://console.cloud.google.com/apis/library/vertexai.googleapis.com

# =============================================================================
# Google Maps API (for real navigation and place search)
# Get a key at: https://developers.google.com/maps/documentation/javascript/get-api-key
# =============================================================================
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# =============================================================================
# Emergency Contact Configuration (not implemented yet)
# =============================================================================
EMERGENCY_CONTACT_EMAIL=emergency@example.com
EMERGENCY_CONTACT_PHONE=+1234567890

# =============================================================================
# Encryption Key (generate a random 32-byte key for production)
# openssl rand -hex 32
# =============================================================================
ENCRYPTION_KEY=your-encryption-key

# =============================================================================
# TTS Configuration (optional)
# =============================================================================
TTS_VOICE=en-US-Neural2-F
TTS_SPEED=1.0